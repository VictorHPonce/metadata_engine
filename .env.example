# =================================================================
# FABRIC - ARCHIVO DE CONFIGURACIÓN DE EJEMPLO (.env)
# Instrucciones: Copia este archivo como '.env' y rellena los datos.
# =================================================================

# --- BASE DE DATOS (PostgreSQL) ---
# En local suele ser localhost:5432, en Docker usar el nombre del servicio
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/fabric
SPRING_DATASOURCE_USERNAME=tu_usuario
SPRING_DATASOURCE_PASSWORD=tu_password_seguro

# --- SEGURIDAD (JWT) ---
# Genera una clave segura de al menos 32 caracteres
JWT_SECRET=tu_clave_secreta_super_larga_y_aleatoria_123456
JWT_EXPIRATION=86400000

# --- INTEGRACIÓN TELEGRAM ---
TELEGRAM_BOT_TOKEN=123456789:AAFu_Ejemplo_Token_Aqui
TELEGRAM_CHAT_ID=-100123456789

# --- SCRAPER CONFIG ---
# Si decides activar el scraper en algún momento
CHROME_BIN_PATH=/usr/bin/google-chrome
SCRAPER_MAX_RETRIES=3

# --- PERFILES DE SPRING ---
# default, dev, prod
SPRING_PROFILES_ACTIVE=default